# Gutter - Journal Configuration

# Server
PORT=3000
HOST=localhost

# Auth (single user — set password to enable, leave empty to disable)
AUTH_PASSWORD=your-password-here
AUTH_SECRET=change-this-to-something-random
SESSION_MAX_AGE_DAYS=30

# Database
DATABASE_PATH=./gutter-journal.db

# Theme (optional - defaults to cyberpink)
DEFAULT_THEME=cyberpink

# Apple Calendars to sync (comma-separated names)
CALENDARS=Calendar,Family Calendar,Home,JW,School

# Ollama (AI features)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:latest
JOURNAL_COMMAND_MODEL=qwen3:latest

# Jira (meeting prep context)
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-api-token
JIRA_PROJECTS=GDEV,ISE

# Slack (meeting prep context)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNELS=C029BN2FBPD|team-hardcore-developer-chat,C027SHEDUET|team-senior-devs

# Whisper (voice transcription)
WHISPER_MODEL_PATH=~/.cache/whisper/ggml-base.en.bin

# Calendar CLI path (macOS only — install with: npm install -g @joargp/accli)
ACCLI_CMD=/path/to/accli
